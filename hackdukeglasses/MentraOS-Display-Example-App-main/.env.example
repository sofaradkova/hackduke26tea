# MentraOS app port. Keep this different from your Next.js ClassWatch app.
PORT=3001

# Must exactly match the package name registered in the MentraOS console.
PACKAGE_NAME=com.yourname.classwatchmentra

# MentraOS developer API key.
MENTRAOS_API_KEY=your_api_key_here

# Base URL for the running ClassWatch dashboard app.
# Local example: http://localhost:3000
# Vercel example: https://your-classwatch-app.vercel.app
CLASSWATCH_BASE_URL=http://localhost:3000

# Optional default class to auto-open on session start.
DEFAULT_CLASS_ID=

# Polling intervals in milliseconds.
POLL_CLASSES_MS=60000
POLL_ALERTS_MS=5000
POLL_SUMMARY_MS=10000
POLL_STUDENTS_MS=15000

# Request timeout in milliseconds.
REQUEST_TIMEOUT_MS=8000

# Display/logging options.
MENTRA_VIEW_TYPE=PINNED
LOG_LEVEL=info
